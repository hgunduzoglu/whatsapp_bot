# Copy this file to .env and fill in your own values.
# NEVER commit the real .env file — it contains secrets.

NODE_ENV=development
PORT=3000

# PostgreSQL connection (docker-compose exposes it on port 5434)
DATABASE_URL=postgresql://app:app@localhost:5434/whatsapp_crm?schema=public
# Production only (docker-compose.prod.yml): password for the postgres container.
# DATABASE_URL/REDIS_URL are wired automatically inside the prod stack.
POSTGRES_PASSWORD=
# Separate database used by integration tests (docker-compose "test" profile, port 5435)
TEST_DATABASE_URL=postgresql://app:app@localhost:5435/whatsapp_crm_test?schema=public
# Redis connection (docker-compose exposes it on port 6380)
REDIS_URL=redis://localhost:6380

# Business timezone used for dates and reminders
APP_TIMEZONE=Europe/Istanbul

# --- Meta WhatsApp Cloud API credentials ---
# From https://developers.facebook.com -> your app -> WhatsApp -> API Setup
WHATSAPP_ACCESS_TOKEN=your_access_token_here
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here
WHATSAPP_BUSINESS_ACCOUNT_ID=your_business_account_id_here
# Sandbox sender number provided by Meta (informational)
WHATSAPP_TEST_PHONE_NUMBER=your_test_phone_number_here
# Any random string; must match the token you enter in the Meta webhook config
WHATSAPP_VERIFY_TOKEN=choose_a_random_verify_token
# App secret from Meta app settings; used to verify webhook signatures
WHATSAPP_APP_SECRET=your_app_secret_here
# true = log outgoing messages instead of calling the Meta API (local development)
WHATSAPP_DRY_RUN=true

# Comma separated phone numbers allowed to use the bot, digits only with country code
# Example: 905321234567,905339876543
AUTHORIZED_WHATSAPP_PHONES=
# false = silently ignore strangers (recommended; replying opens a paid conversation)
REPLY_TO_UNAUTHORIZED=false

# Bot session expires after this many minutes of inactivity
SESSION_TTL_MINUTES=30
# Hour of day (Istanbul time) at which reminders are sent
REMINDER_SEND_HOUR=9

# --- Admin panel API ---
# Secret used to sign admin JWTs; generate with: openssl rand -hex 32
JWT_SECRET=
JWT_EXPIRES_IN=7d
# Initial owner account, created automatically on first boot
ADMIN_EMAIL=
ADMIN_PASSWORD=
# Browser origins allowed to call the API (the admin panel URL)
ADMIN_ORIGINS=http://localhost:5173

# --- PostgreSQL backups to Cloudflare R2 (optional; disabled while unset) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_ENDPOINT=
# Cron for the scheduled backup (Istanbul time)
BACKUP_CRON=0 3 * * *

# --- Production deployment (docker-compose.prod.yml) ---
# Domains served by Caddy and the e-mail used for Let's Encrypt
ACME_EMAIL=you@example.com
SITE_DOMAIN=example.com
WWW_DOMAIN=www.example.com
API_DOMAIN=api.example.com
ADMIN_DOMAIN=admin.example.com
